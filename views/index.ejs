<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Management System - Dashboard</title>
   
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
   
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
 
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">
            <a class="navbar-brand navbar-brand-custom" href="/students">
                <i class="bi bi-mortarboard-fill"></i> Student Management System
            </a>
        </div>
    </nav>

    <div class="main-wrapper">
        <div class="container-box">
         
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                <div>
                    <h1 class="main-title mb-0">All Registered Students</h1>
                    <p class="text-muted mt-2 mb-0">Manage all student records in one secure system.</p>
                </div>
                <div>
                    <a href="/students/add" class="btn btn-red">
                        + Add Student
                    </a>
                </div>
            </div>

            <% if (students && students.length > 0) { %>
                <div class="table-responsive table-responsive-custom">
                    <table class="table table-custom text-center align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Roll No</th>
                                <th>Course</th>
                                <th>Age</th>
                                <th>Email</th>
                                <th>City</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% students.forEach(student => { %>
                                <tr>
                                    <td class="fw-semibold text-dark"><%= student.name %></td>
                                    <td><%= student.rollno %></td>
                                    <td><%= student.course %></td>
                                    <td><%= student.age %> yrs</td>
                                    <td><%= student.email %></td>
                                    <td><%= student.city %></td>
                                    <td>
                                        <div class="d-inline-flex">
                                            <a href="/students/view/<%= student._id %>" class="btn btn-info btn-sm me-1 px-3 action-btn-text">
                                                View
                                            </a>
                                            <a href="/students/edit/<%= student._id %>" class="btn btn-warning btn-sm me-1 px-3 action-btn-text">
                                                Edit
                                            </a>
                                            <a href="/students/delete/<%= student._id %>" class="btn btn-danger btn-sm px-3 action-btn-text">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <h3 class="text-dark">No Students Registered</h3>
                    <p class="text-muted">Click the "+ Add Student" button to insert records.</p>
                </div>
            <% } %>

         
            <p class="footer-text mb-0">&copy; <%= new Date().getFullYear() %> Student Management System. Built with Bootstrap 5.</p>
        </div>
    </div>

   
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>