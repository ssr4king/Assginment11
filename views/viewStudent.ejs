<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Student Details - Student Management System</title>
   
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
 
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">
            <a class="navbar-brand navbar-brand-custom" href="/students">
                <i class="bi bi-mortarboard-fill"></i> Student Management System
            </a>
        </div>
    </nav>

    
    <div class="main-wrapper">
        <div class="card-box-centered">
          
            <div class="details-avatar-container">
                <div class="details-avatar">
                    <%= student.name ? student.name.charAt(0).toUpperCase() : 'S' %>
                </div>
            </div>

        
            <div class="main-title-centered mb-4">
                <h1 class="main-title mb-1"><%= student.name %></h1>
                <span class="badge bg-danger rounded-pill px-3 py-1.5 mt-2 fw-semibold">Roll No: <%= student.rollno %></span>
            </div>

   
            <ul class="details-list">
           
                <li class="details-item">
                    <span class="details-label">
                        <i class="bi bi-book-half text-danger"></i> Course
                    </span>
                    <span class="details-val"><%= student.course %></span>
                </li>

             
                <li class="details-item">
                    <span class="details-label">
                        <i class="bi bi-calendar-event text-danger"></i> Age
                    </span>
                    <span class="details-val"><%= student.age %> Years</span>
                </li>

                <li class="details-item">
                    <span class="details-label">
                        <i class="bi bi-envelope-at text-danger"></i> Email
                    </span>
                    <span class="details-val">
                        <a href="mailto:<%= student.email %>" class="text-black text-decoration-none"><%= student.email %></a>
                    </span>
                </li>

               
                <li class="details-item">
                    <span class="details-label">
                        <i class="bi bi-geo-alt text-danger"></i> City
                    </span>
                    <span class="details-val"><%= student.city %></span>
                </li>
            </ul>

            <div class="d-flex align-items-center justify-content-between">
                <a href="/students" class="btn btn-outline-red">
                    <i class="bi bi-arrow-left-short fs-5"></i> Back to Dashboard
                </a>
                <a href="/students/edit/<%= student._id %>" class="btn btn-red">
                    <i class="bi bi-pencil-square"></i> Edit Profile
                </a>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>